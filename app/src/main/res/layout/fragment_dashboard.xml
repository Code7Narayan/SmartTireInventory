<?xml version="1.0" encoding="utf-8"?>
<!-- FILE: res/layout/fragment_dashboard.xml  (REDESIGNED — clean minimal daily insights) -->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- ── Header: Title + Export ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_medium">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_xlarge"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvDashboardDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_size_small"
                        android:text="Today"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportDailyPdf"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Export"
                    android:textAllCaps="false"
                    app:strokeColor="@color/primary"
                    app:icon="@drawable/ic_pdf"
                    app:iconGravity="textStart"/>
            </LinearLayout>

            <!-- ── Date Picker Row ────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_medium"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/primary"
                        android:layout_marginEnd="@dimen/margin_small"/>
                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_medium"
                        android:textStyle="bold"
                        android:text="Today"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickDate"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change Date"
                        android:textAllCaps="false"
                        app:rippleColor="@color/primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Top 4 KPI Cards: Stock + Revenue ───────────────────────── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:layout_marginBottom="@dimen/margin_small">

                <!-- Total Stock Available -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_stock" android:tint="@color/info"/>
                        <TextView android:id="@+id/tvTotalStock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_xlarge" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Stock" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Today Revenue -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_money" android:tint="@color/success"/>
                        <TextView android:id="@+id/tvDailyRevenue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹0" android:textColor="@color/success"
                            android:textSize="@dimen/text_size_large" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/tvRevenueLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Revenue" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Date Added Stock -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_add" android:tint="@color/primary"/>
                        <TextView android:id="@+id/tvDailyAdded"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_xlarge" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Added Stock" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Date Sold Stock -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_sell" android:tint="@color/warning"/>
                        <TextView android:id="@+id/tvDailySold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/warning"
                            android:textSize="@dimen/text_size_xlarge" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sold Stock" android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_small"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- ── Added vs Sold Comparison Bar ───────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:layout_marginBottom="@dimen/margin_medium"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_medium">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/margin_medium">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Added vs Sold"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_medium"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvComparisonDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_small"
                            android:text="Today"/>
                    </LinearLayout>

                    <!-- Added Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Added"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"/>
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="1"
                            android:background="@color/divider"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/barAdded"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/primary"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tvBarAddedCount"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Sold Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Sold"
                            android:textColor="@color/warning"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"/>
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="1"
                            android:background="@color/divider"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/barSold"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/warning"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tvBarSoldCount"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/warning"
                            android:textSize="@dimen/text_size_normal"
                            android:textStyle="bold"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Secondary Stats Row: Customers + Outstanding ───────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/margin_medium">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_company" android:tint="@color/primary"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvTotalCustomers"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_large" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Customers" android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_small"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="@dimen/padding_small">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_warning" android:tint="@color/warning"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvTotalOutstanding"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₹0" android:textColor="@color/warning"
                                android:textSize="@dimen/text_size_medium" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Outstanding" android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_small"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── Daily Added Stock Detail ───────────────────────────────── -->
            <TextView
                android:id="@+id/tvAddedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock Added"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <TextView
                android:id="@+id/tvNoAddedStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No stock added on this date"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_size_normal"
                android:padding="@dimen/padding_medium"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDailyAdded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/margin_medium"/>

            <!-- ── Daily Sold Detail ───────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvSoldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sales Made"
                android:textColor="@color/warning"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <TextView
                android:id="@+id/tvNoSoldStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No sales on this date"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_size_normal"
                android:padding="@dimen/padding_medium"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDailySold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/margin_medium"/>

            <!-- ── Low Stock Alert ────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠  Low Stock"
                android:textColor="@color/warning"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLowStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/margin_medium"/>

            <TextView
                android:id="@+id/tvNoLowStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  All products are well stocked"
                android:textColor="@color/success"
                android:textSize="@dimen/text_size_normal"
                android:textAlignment="center"
                android:padding="@dimen/padding_medium"
                android:visibility="gone"/>

            <!-- ── Top Debtors ─────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Debtors"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/margin_small"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTopDebtors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="@dimen/margin_large"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>