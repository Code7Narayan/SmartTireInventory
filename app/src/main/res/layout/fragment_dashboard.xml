<?xml version="1.0" encoding="utf-8"?>
<!--
  FILE: res/layout/fragment_dashboard.xml  (OPTIMIZED)
  KEY FIXES:
    • All RecyclerViews have android:nestedScrollingEnabled="false" so only
      the outer NestedScrollView scrolls — no double-scroll conflict.
    • RecyclerViews use wrap_content height (acceptable here because they show
      a small fixed number of items, typically ≤ 5). For large lists, replace
      with a different pattern (e.g. a single RecyclerView with multiple item
      types). The critical rule is that nestedScrollingEnabled must be false.
    • Removed redundant layout containers and reduced view depth.
    • ProgressBar position is an overlay via FrameLayout, not an extra pass.
    • BarChart gets a fixed 250dp height to avoid re-measuring.
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
      NestedScrollView is the ONLY scrollable container here.
      All RecyclerViews inside must have nestedScrollingEnabled=false.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Header ─────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDashboardDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:text="Today"/>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportDailyPdf"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Export"
                    android:textAllCaps="false"
                    app:strokeColor="@color/primary"
                    app:icon="@drawable/ic_pdf"
                    app:iconGravity="textStart"/>

            </LinearLayout>

            <!-- ── KPI Cards 2×2 ──────────────────────────────────────────── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true"
                android:layout_marginBottom="8dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTotalStock"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="8dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_stock" android:tint="@color/info"/>
                        <TextView android:id="@+id/tvTotalStock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/text_primary"
                            android:textSize="20sp" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Stock" android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRevenue"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="8dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_money" android:tint="@color/success"/>
                        <TextView android:id="@+id/tvDailyRevenue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="₹0" android:textColor="@color/success"
                            android:textSize="18sp" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/tvRevenueLabel"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Revenue" android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAddedStock"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="8dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_add" android:tint="@color/primary"/>
                        <TextView android:id="@+id/tvDailyAdded"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/primary"
                            android:textSize="20sp" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Added Stock" android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSoldStock"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="8dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_sell" android:tint="@color/warning"/>
                        <TextView android:id="@+id/tvDailySold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/warning"
                            android:textSize="20sp" android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sold Stock" android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- ── Monthly Bar Chart ─────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Monthly Analytics"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChartFilter"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Revenue"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_menu"
                            app:iconSize="14dp"/>

                    </LinearLayout>

                    <!-- Fixed height prevents infinite measure cycle -->
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChartMonthly"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Daily Added vs Sold ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Daily Added vs Sold"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPickDate"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change Date"
                            android:textAllCaps="false"
                            app:rippleColor="@color/primary"/>

                    </LinearLayout>

                    <!-- Added bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Added"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="1"
                            android:background="@color/divider"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/barAdded"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/primary"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvBarAddedCount"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <!-- Sold bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:text="Sold"
                            android:textColor="@color/warning"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="22dp"
                            android:layout_weight="1"
                            android:background="@color/divider"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/barSold"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="@color/warning"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvBarSoldCount"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/warning"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Customers + Outstanding ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCustomers"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="8dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_company" android:tint="@color/primary"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvTotalCustomers"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textColor="@color/text_primary"
                                android:textSize="18sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Customers" android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOutstanding"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/card_background"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="8dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_warning" android:tint="@color/warning"
                            android:layout_marginEnd="8dp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView android:id="@+id/tvTotalOutstanding"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₹0" android:textColor="@color/warning"
                                android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Outstanding" android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Low Stock section ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠  Low Stock"
                android:textColor="@color/warning"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!--
              CRITICAL: nestedScrollingEnabled="false" prevents the inner RecyclerView
              from intercepting touch events and competing with NestedScrollView.
              wrap_content height is acceptable here because the low-stock list is small.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLowStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvNoLowStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓  All products are well stocked"
                android:textColor="@color/success"
                android:textSize="14sp"
                android:textAlignment="center"
                android:padding="16dp"
                android:visibility="gone"/>

            <!-- ── Most Sold section ──────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Most Sold"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMostSold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="4dp"/>

            <!-- ── Top Debtors section ────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Debtors"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTopDebtors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>